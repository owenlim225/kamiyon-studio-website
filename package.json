{
  "name": "kamiyon-studio-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:staging": "opennextjs-cloudflare build && opennextjs-cloudflare deploy --env staging",
    "deploy:prod": "opennextjs-cloudflare build && opennextjs-cloudflare deploy --env production",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "knip": "knip",
    "sanity": "sanity",
    "sanity:dev": "sanity dev",
    "sanity:deploy": "sanity deploy",
    "sanity:schema": "sanity schema extract"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@opennextjs/cloudflare": "^1.20.2",
    "@sanity/image-url": "^2.1.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "@sanity/ui": "^3.3.5",
    "next": "16.2.11",
    "next-sanity": "^13.1.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanity": "^5.31.1",
    "styled-components": "^6.4.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sanity/vision": "^5.31.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "jsdom": "^29.1.1",
    "knip": "^6.25.0",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.113.0"
  }
}
