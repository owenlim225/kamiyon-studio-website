# Site URL for sitemap, canonical URLs, and Open Graph (no trailing slash)
# Local/dev default below. Production: https://kamiyonstudio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Sanity CMS (Phase B+) ---
# Create a project at https://www.sanity.io/manage or run: pnpm sanity init
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Server-only read token (optional for private datasets)
SANITY_API_READ_TOKEN=
# Webhook auth for on-demand revalidation (Phase E)
SANITY_REVALIDATE_SECRET=
# Optional hostname for sanity deploy / hosted studio
SANITY_STUDIO_HOSTNAME=

# --- Cloudflare R2 (Phase E upload; URL resolution works when base is set) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=

# --- Contact form (Phase F) ---
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=

# --- Analytics (Phase F) ---
# NEXT_PUBLIC_CF_WEB_ANALYTICS_TOKEN=
