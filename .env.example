# Sanity CMS
CMS_PROJECT_ID=
CMS_DATASET=production

# Optional for authenticated server-side reads or future draft/preview support.
# Never commit a real token.
CMS_API_TOKEN=

# Absolute production URL (no trailing slash) — used for canonical links,
# OpenGraph/Twitter image URLs, sitemap.xml, and robots.txt. Falls back to
# http://localhost:3000 for local dev/build. Deployment target is still an
# open question (see context/progress-tracker.md) — set this before launch.
NEXT_PUBLIC_SITE_URL=
