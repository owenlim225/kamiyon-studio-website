# Payload CMS + Postgres (required for /admin and live CMS fetches)
# Never commit real secrets. Generate PAYLOAD_SECRET with: openssl rand -base64 32
# PAYLOAD_SECRET is required whenever DATABASE_URL is set (enforced at startup).
PAYLOAD_SECRET=
DATABASE_URL=

# Site URL for sitemap, canonical URLs, and Open Graph (no trailing slash)
# Local/dev default below. Production (Vercel): https://kamiyonstudio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
