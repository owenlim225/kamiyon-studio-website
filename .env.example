# =============================================================================
# Kamiyon Studio Website — environment variables
# Copy to `.env.local` for local Next.js. Never commit real secrets.
# Runtime Worker secrets/vars are set in Cloudflare (see context/deploy-runbook.md).
# =============================================================================

# --- App environment (Phase E) ---
# local | staging | production — used instead of Vercel VERCEL_ENV
APP_ENV=local

# Site URL for sitemap, canonical URLs, and Open Graph (no trailing slash)
# Local: http://localhost:3000
# Staging (workers.dev or staging host): set per environment
# Production: https://kamiyonstudio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Sanity CMS (Phase B+) ---
# Create a project at https://www.sanity.io/manage or run: pnpm sanity init
NEXT_PUBLIC_SANITY_PROJECT_ID=c6ej1xoj
NEXT_PUBLIC_SANITY_DATASET=kamiyon
# Hosted Studio (`pnpm sanity:deploy`) — must use static process.env.SANITY_STUDIO_* access.
# Repo defaults in sanity/env.ts also fall back to c6ej1xoj / kamiyon if unset.
SANITY_STUDIO_PROJECT_ID=c6ej1xoj
SANITY_STUDIO_DATASET=kamiyon
# Server-only read token (optional for private datasets)
SANITY_API_READ_TOKEN=
# Webhook auth for on-demand revalidation (Phase E) — POST /api/revalidate
SANITY_REVALIDATE_SECRET=
# Hosted Studio (ADR-007) — `pnpm sanity:deploy` → https://{hostname}.sanity.studio
# Default hostname: kamiyon. Worker `/studio` redirects here.
SANITY_STUDIO_HOSTNAME=kamiyon
# Optional full Studio URL (overrides hostname). Also used for upload CORS allowlist.
NEXT_PUBLIC_SANITY_STUDIO_URL=https://kamiyon.sanity.studio
# Absolute site origin for Studio → POST /api/media/upload (required for hosted Studio)
# Staging: https://kamiyon-studio-website-staging.<subdomain>.workers.dev
# Production: https://kamiyonstudio.com
SANITY_STUDIO_API_ORIGIN=

# --- Cloudflare R2 media (Phase E) ---
# Prefer Worker R2 binding MEDIA_BUCKET in production; these help local/tools:
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# Public CDN base (no trailing slash)
# Staging: https://media-staging.kamiyonstudio.com
# Production: https://media.kamiyonstudio.com
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=

# Studio / upload API bearer secret (Phase E) — Authorization: Bearer <secret>
# Server (Worker / Next API): validates uploads at POST /api/media/upload
MEDIA_UPLOAD_SECRET=
# Sanity Studio client (Vite embeds SANITY_STUDIO_* / NEXT_PUBLIC_*):
# Prefer SANITY_STUDIO_MEDIA_UPLOAD_SECRET for Studio; NEXT_PUBLIC_ is a fallback.
# Must match MEDIA_UPLOAD_SECRET when testing Studio → API uploads locally.
# SANITY_STUDIO_MEDIA_UPLOAD_SECRET=
# NEXT_PUBLIC_MEDIA_UPLOAD_SECRET=

# --- Cloudflare account / Wrangler (local CLI + CI) ---
# Account ID also used as GitHub Actions secret CLOUDFLARE_ACCOUNT_ID
# CLOUDFLARE_ACCOUNT_ID=
# Prefer `wrangler login` locally; CI uses CLOUDFLARE_API_TOKEN secret
# CLOUDFLARE_API_TOKEN=

# --- Cloudflare Web Analytics (Phase E / T14) ---
NEXT_PUBLIC_CF_WEB_ANALYTICS_TOKEN=

# --- Contact form (Phase F) ---
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=
