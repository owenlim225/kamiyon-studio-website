# Sanity CMS (required for Studio and live CMS fetches — removed in Phase 4)
CMS_PROJECT_ID=
CMS_DATASET=production

# Optional: read token for private datasets, draft preview, or server-side fetches.
# Required for Sanity Presentation tool draft mode (/api/draft-mode/enable).
CMS_API_TOKEN=

# Payload CMS + Postgres (required for /admin from Phase 1 onward)
PAYLOAD_SECRET=
DATABASE_URL=

# Site URL for sitemap, canonical URLs, Open Graph, and Studio preview iframe origin
NEXT_PUBLIC_SITE_URL=http://localhost:3000
